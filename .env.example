# Application Configuration
SPRING_APPLICATION_NAME=car_rental_management
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api

# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/carrentaldb
DB_USERNAME=root
DB_PASSWORD=
DB_DRIVER=com.mysql.cj.jdbc.Driver

# JPA/Hibernate Configuration
JPA_HIBERNATE_DDL_AUTO=validate
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false
JPA_USE_SQL_COMMENTS=false
JPA_OPEN_IN_VIEW=false

# AWS S3 Configuration
AWS_S3_ACCESS_KEY=
AWS_S3_SECRET_KEY=
AWS_S3_REGION=ap-southeast-2
AWS_S3_BUCKET_NAME=project-car-rental-storage

# File Upload Configuration
AWS_S3_MAX_FILE_SIZE=52428800
AWS_S3_ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx,xls,xlsx,txt,zip

# Video Upload Configuration
AWS_S3_MAX_VIDEO_SIZE=5368709120
AWS_S3_ALLOWED_VIDEO_TYPES=mp4,avi,mov,mkv,flv,wmv,webm,3gp

# Spring Web Configuration
MULTIPART_MAX_FILE_SIZE=500MB
MULTIPART_MAX_REQUEST_SIZE=500MB

# JWT Configuration
JWT_SECRET=your_very_secret_key_here_minimum_32_characters_long_required_for_hs256_algorithm_security
JWT_EXPIRATION=86400000

